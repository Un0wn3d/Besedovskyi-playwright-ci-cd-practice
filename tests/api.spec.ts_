import { test, expect } from '@playwright/test'

test('Отримання списку постів через GET', async ({ request }) => {
  // Виконуємо GET запит до endpoint
  const response = await request.get('https://jsonplaceholder.typicode.com/posts/1')

  // Перевірка статусу успішності відповіді
  expect(response).toBeOK()

  // Отримання тіла відповіді у форматі JSON
  const body = await response.json()

  // Валідація даних: перевіряємо, що повернувся об'єкт із правильним ID
  expect(body).toMatchObject({
    id: 1,
    userId: 1,
  })

  // Перевіряємо, що поле title не порожнє і є типом string
  expect(typeof body.title).toBe('string')
  expect(body.title.length).toBeGreaterThan(0)

  // Можна перевірити отримувані дані, розкоментувавши рядок нижче
  // console.log(body)
})

test('Створення нового поста через POST', async ({ request }) => {
  const response = await request.post('https://jsonplaceholder.typicode.com/posts', {
    data: {
      title: 'Мій тестовий пост',
      body: 'Це зміст мого запиту',
      userId: 1,
    },
    headers: {
      'Content-type': 'application/json; charset=UTF-8',
    },
  })

  // Перевірка статус-коду: 201 Created (успішне створення)
  expect(response.status()).toBe(201)

  // Отримання тіла відповіді у форматі JSON
  const body = await response.json()

  // Перевірка, що сервер повернув надіслані дані + згенерований ID
  expect(body).toMatchObject({
    title: 'Мій тестовий пост',
    body: 'Це зміст мого запиту',
    userId: 1,
  })
  expect(body).toHaveProperty('id')

  // Можна перевірити збережені на сервері дані, розкоментувавши рядок нижче
  // console.log(body)
})

test('Отримання повного списку GET', async ({ request }) => {
  const response = await request.get('https://jsonplaceholder.typicode.com/posts')

  expect(response).toBeOK()

  const body = await response.json()

  expect(Array.isArray(body)).toBeTruthy()
  expect(body.length).toBeGreaterThan(0)
})

test('Негативний тест: GET', async ({ request }) => {
  const response = await request.get('https://jsonplaceholder.typicode.com/posts/9090')

  expect(response.status()).toBe(404)
  expect(response.ok()).toBeFalsy()
})

test('Видалення поста через DELETE', async ({ request }) => {
  const response = await request.delete('https://jsonplaceholder.typicode.com/posts/1')

  expect(response.status()).toBe(200)

  const body = await response.json()
  expect(body).toEqual({})

  const repeatedResponse = await request.delete('https://jsonplaceholder.typicode.com/posts/1')

  expect(repeatedResponse.status()).toBe(200)

  const repeatedBody = await repeatedResponse.json()
  expect(repeatedBody).toEqual(body)
})